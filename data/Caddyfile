{
        acme_ca https://acme-v02.api.letsencrypt.org/directory
}

http://xxx.yyy.zzz {
        redir https://{host}{uri} permanent
}

xxx.yyy.zzz {
        encode gzip zstd

        log {
                output file /var/log/caddy/access.log
        }

        route {
                handle /admin {
                        rewrite * /admin.html
                        reverse_proxy 127.0.0.1:8081
                }

                @sub path /api/*
                handle @sub {
                    reverse_proxy 127.0.0.1:8081
                }

                @xhttp path /xhttp*
                handle @xhttp {
                        reverse_proxy 127.0.0.1:1234
                }

                handle {
                        respond "hello world!" 200
                }
        }
}
